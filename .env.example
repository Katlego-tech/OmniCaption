# OmniCaption — root environment template.
# Copy to `.env` and fill in. pydantic-settings validates these at startup and refuses to
# boot if a required value is missing. The captioner reads the OMNICAPTION_* vars
# (see services/captioner/.env.example for the authoritative, per-service list).

# --- I/O (the harness mounts these; override only for local runs) ------------
OMNICAPTION_INPUT_PATH=/input/tasks.json
OMNICAPTION_OUTPUT_PATH=/output/results.json

# --- Models / Fireworks AI API -----------------------------------------------
FIREWORKS_API_KEY=fw_your_api_key_here
OMNICAPTION_FIREWORKS_API_URL=https://api.fireworks.ai/inference/v1
OMNICAPTION_FIREWORKS_WHISPER_MODEL=whisper-v3
OMNICAPTION_FIREWORKS_VLM_MODEL=accounts/fireworks/models/qwen2-vl-72b-instruct
OMNICAPTION_MAX_NEW_TOKENS=256

# --- AMD / ROCm --------------------------------------------------------------
OMNICAPTION_GFX_ARCH=gfx1100                # target arch: gfx942 (MI300X), gfx1100 (RX 7900 XTX), gfx1032 (RX 6600)...
# HSA_OVERRIDE_GFX_VERSION=10.3.0           # only for cards outside the ROCm support matrix
# PYTORCH_ROCM_ARCH=gfx1100                 # set before compiling CTranslate2-HIP

# --- Vision / synthesis tuning -----------------------------------------------
OMNICAPTION_KEYFRAME_THRESHOLD=30.0         # pixel-variance scene-change threshold
OMNICAPTION_MAX_KEYFRAMES=8                 # cap on keyframes per clip (token budget)
OMNICAPTION_MAX_NEW_TOKENS=256              # per caption

# --- Hugging Face access (gated Gemma model) ---------------------------------
# HF_TOKEN=hf_xxx

# --- Track 3 (stretch) Video-Oracle ------------------------------------------
# OMNICAPTION_VLLM_MODEL=google/gemma-4-31B-it
# OMNICAPTION_VLLM_URL=http://localhost:8000/v1
