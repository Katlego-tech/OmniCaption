# OmniCaption — root environment template.
# Copy to `.env` and fill in. pydantic-settings validates these at startup and refuses to
# boot if a required value is missing. The captioner reads the OMNICAPTION_* vars
# (see services/captioner/.env.example for the authoritative, per-service list).

# --- I/O (the harness mounts these; override only for local runs) ------------
# NOTE: Settings reads *_DIR variables (tasks.json / results.json names are fixed).
OMNICAPTION_INPUT_DIR=/input
OMNICAPTION_OUTPUT_DIR=/output
OMNICAPTION_WORK_DIR=/tmp/omnicaption

# --- Models / Fireworks AI API -----------------------------------------------
FIREWORKS_API_KEY=fw_your_api_key_here
OMNICAPTION_FIREWORKS_API_URL=https://api.fireworks.ai/inference/v1
OMNICAPTION_FIREWORKS_WHISPER_MODEL=whisper-v3
OMNICAPTION_FIREWORKS_VLM_MODEL=accounts/fireworks/models/kimi-k2p6
OMNICAPTION_MAX_NEW_TOKENS=4096

# --- AMD / ROCm --------------------------------------------------------------
OMNICAPTION_GFX_ARCH=gfx1100                # target arch: gfx942 (MI300X), gfx1100 (RX 7900 XTX), gfx1032 (RX 6600)...
# HSA_OVERRIDE_GFX_VERSION=10.3.0           # only for cards outside the ROCm support matrix
# PYTORCH_ROCM_ARCH=gfx1100                 # set before compiling CTranslate2-HIP

# --- Vision / synthesis tuning -----------------------------------------------
OMNICAPTION_KEYFRAME_THRESHOLD=30.0         # pixel-variance scene-change threshold
OMNICAPTION_MAX_KEYFRAMES=8                 # cap on keyframes per clip (token budget)

# --- Hugging Face access ------------------------------------------------------
# Not needed: the Whisper weights (Systran/faster-whisper-large-v3) are ungated
# and baked into the image at build time.
# HF_TOKEN=hf_xxx

# --- Track 3 (stretch) Video-Oracle ------------------------------------------
# OMNICAPTION_VLLM_MODEL=google/gemma-4-31B-it
# OMNICAPTION_VLLM_URL=http://localhost:8000/v1

# --- Local STT / dev tuning --------------------------------------------------
# Whisper model size (tiny, base, small, medium, large-v3)
OMNICAPTION_WHISPER_MODEL_SIZE=large-v3
# Download weights from Hugging Face Hub (0 = online check/download, 1 = offline)
HF_HUB_OFFLINE=0

# --- FastAPI Backend API Settings ---------------------------------------------
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Root data directory for SQLite user DB, auth keys, and media
DATA_DIR=./data

# HMAC signing secret for auth tokens. Leave empty to auto-generate a secure key
# AUTH_SECRET=

# Optional Redis URL for shared rate-limiting (degrades to in-memory if empty)
# REDIS_URL=redis://localhost:6379/0

# Docker configuration used by the API runner
CAPTIONER_IMAGE=omnicaption-captioner:latest
# CAPTIONER_CMD=
