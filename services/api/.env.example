# OmniCaption backend API configuration (see app/core/config.py).
# Copy to .env and adjust. Names follow docs/18-frontend-architecture.md §6.

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# Root data directory. The API reads/writes:
#   <DATA_DIR>/input/tasks.json     (captioner input manifest)
#   <DATA_DIR>/output/results.json  (captioner output)
#   <DATA_DIR>/media/               (files served via /api/media)
#   <DATA_DIR>/auth.db              (SQLite user accounts)
DATA_DIR=./data

# HMAC signing secret for auth tokens. Leave UNSET to auto-generate a random
# secret persisted at <DATA_DIR>/auth_secret.key (single-instance dev). Set it
# explicitly to a strong random value for production / multi-instance so every
# instance signs with the same key.
# AUTH_SECRET=
# Auth token lifetime, in hours (default one week).
TOKEN_TTL_HOURS=168

# Optional shared rate-limit store for multi-instance deployments. Requires the
# optional `redis` package (pip install redis). Leave unset for per-process
# in-memory limiting; if set but unreachable, the API degrades to in-memory.
# REDIS_URL=redis://localhost:6379/0

# Captioner container image used by the default run command.
CAPTIONER_IMAGE=omnicaption-captioner:latest

# Optional: full override of the pipeline run command (shell-split, not a shell line).
# When unset, the API runs:  docker run --rm -v <input>:/input -v <output>:/output <image>
# CAPTIONER_CMD=

# Fireworks endpoint used by /api/keys/validate.
FIREWORKS_API_URL=https://api.fireworks.ai/inference/v1
