# OmniCaption captioner configuration. Copy to `.env` and adjust.
# All variables are read by app.core.config.Settings (prefix OMNICAPTION_).

# --- I/O paths (the eval harness mounts /input and /output) ---
OMNICAPTION_INPUT_DIR=/input
OMNICAPTION_OUTPUT_DIR=/output
OMNICAPTION_WORK_DIR=/tmp/omnicaption

# --- Models ---
OMNICAPTION_WHISPER_MODEL_SIZE=large-v3
OMNICAPTION_WHISPER_COMPUTE_TYPE=float16
OMNICAPTION_GEMMA_MODEL_ID=google/gemma-4-e4b-it

# --- Vision ---
OMNICAPTION_KEYFRAME_THRESHOLD=30.0
OMNICAPTION_MAX_KEYFRAMES=8

# --- Synthesis / generation ---
OMNICAPTION_MAX_NEW_TOKENS=256
OMNICAPTION_LOAD_IN_4BIT=true
OMNICAPTION_ALPHA=0.6
OMNICAPTION_BETA=0.4

# --- GPU / ROCm (leave unset to auto-detect) ---
# OMNICAPTION_GFX_ARCH=gfx942
# OMNICAPTION_HSA_OVERRIDE_GFX_VERSION=9.4.2

# --- Timeouts / latency budgets (seconds) ---
OMNICAPTION_DOWNLOAD_TIMEOUT_S=60
OMNICAPTION_PER_REQUEST_BUDGET_S=30
OMNICAPTION_TOTAL_RUNTIME_BUDGET_S=600

# --- Logging ---
OMNICAPTION_LOG_LEVEL=INFO
